msgstr ":py:obj:`KeyedStateContext <ray.klein.state.KeyedStateContext>`"

msgid ":py:obj:`KeyGroupRange <ray.klein.state.KeyGroupRange>`"
msgstr ":py:obj:`KeyGroupRange <ray.klein.state.KeyGroupRange>`"

