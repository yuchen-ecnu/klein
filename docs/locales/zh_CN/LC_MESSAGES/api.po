msgstr ":py:obj:`ListState <ray.klein.state.ListState>`"

msgid ":py:obj:`ListStateDescriptor <ray.klein.state.ListStateDescriptor>`"
msgstr ":py:obj:`ListStateDescriptor <ray.klein.state.ListStateDescriptor>`"

