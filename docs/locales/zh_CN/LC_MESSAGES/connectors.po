"Format-specific options; for `canal-json`, `include_metadata` and "
"`ddl_handling`."
msgstr "格式专用选项；对于 `canal-json`，包括 `include_metadata` 和 `ddl_handling`。"

msgid "`timeout_ms`"
msgstr "`timeout_ms`"

msgid "Poll/read timeout; continuous input uses 1000 ms when unset."
msgstr "轮询/读取超时；未设置时，连续输入使用 1000 ms。"

msgid "Source task resources."
msgstr "Source Task 资源。"

msgid "`memory`, `ray_remote_args`"
msgstr "`memory`、`ray_remote_args`"

msgid "Bounded Ray Data resource options; unsupported for continuous input."
msgstr "有界 Ray Data 资源选项；连续输入不支持。"

msgid ""
"An integer start offset must be non-negative. A naive `datetime` is "
